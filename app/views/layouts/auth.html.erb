<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <title><%= content_for(:title) ? "#{content_for(:title)} | Wishare" : "Wishare - Share Wishlists" %></title>
  <meta name="description" content="<%= content_for(:description) || "Create and share wishlists with friends and family." %>">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#EC4899">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Stylesheets -->
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

  <!-- JavaScript -->
  <%= javascript_importmap_tags %>
</head>

<body class="bg-gray-50 dark:bg-gray-900 transition-colors duration-300">

  <!-- Animated Background -->
  <div class="fixed inset-0 bg-gradient-to-br from-purple-100 via-pink-100 to-rose-100 dark:from-purple-950 dark:via-pink-950 dark:to-rose-950 animate-gradient"></div>

  <!-- Floating Decorative Elements -->
  <div class="fixed top-20 left-10 w-64 h-64 bg-purple-500/20 dark:bg-purple-500/10 rounded-full blur-3xl animate-float"></div>
  <div class="fixed bottom-20 right-10 w-96 h-96 bg-pink-500/20 dark:bg-pink-500/10 rounded-full blur-3xl animate-float" style="animation-delay: 1s;"></div>

  <!-- Main Container -->
  <div class="relative min-h-screen flex items-center justify-center p-4">
    <%= yield %>
  </div>

  <!-- Flash Messages (Toast Style) -->
  <% if flash.any? %>
    <div class="fixed top-4 right-4 z-50 space-y-2">
      <% flash.each do |type, message| %>
        <div class="animate-fade-in-up bg-white dark:bg-gray-800 shadow-2xl rounded-xl p-4 max-w-md border-l-4 <%= type == 'notice' ? 'border-green-500' : 'border-red-500' %>">
          <p class="text-sm font-medium text-gray-900 dark:text-white"><%= message %></p>
        </div>
      <% end %>
    </div>
  <% end %>

</body>
</html>
