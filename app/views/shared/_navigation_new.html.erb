<%#
  WISHARE NAVIGATION - Simplified & Modernized
  Based on app-layout-chrome.html prototype
  Glass morphism design with mobile-first approach
%>

<!-- Desktop Navigation -->
<nav class="nav-desktop nav-glass nav-sticky shadow-lg hidden lg:block">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">

      <!-- Left: Logo + Main Nav -->
      <div class="flex items-center space-x-8">
        <!-- Logo -->
        <%= link_to root_path, class: "logo-container" do %>
          <div class="logo-icon">
            <span class="text-2xl">💝</span>
          </div>
          <span class="logo-text">Wishare</span>
        <% end %>

        <!-- Main Navigation Links -->
        <div class="flex items-center space-x-1">
          <%= link_to root_path, class: "nav-link-top #{request.path == root_path ? 'active' : ''}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
            <%= t('navigation.dashboard') %>
          <% end %>

          <%= link_to wishlists_path, class: "nav-link-top #{request.path.match?(/\/wishlists/) ? 'active' : ''}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path>
            </svg>
            <%= t('navigation.wishlists') %>
          <% end %>

          <%= link_to connections_path, class: "nav-link-top #{request.path.match?(/\/connections/) ? 'active' : ''}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
            <%= t('navigation.connections') %>
          <% end %>
        </div>
      </div>

      <!-- Center: Search Bar (can be added later) -->
      <!--
      <div class="flex-1 max-w-md mx-8">
        <div class="search-bar">
          <input
            type="text"
            placeholder="<%= t('navigation.search_placeholder') %>"
            class="search-input">
          <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
      </div>
      -->

      <!-- Right: Notifications + Dark Mode + User -->
      <div class="flex items-center space-x-4">
        <!-- Notifications Bell -->
        <div class="relative" data-controller="notifications" data-notifications-user-id-value="<%= current_user&.id %>">
          <button data-action="click->notifications#toggle" class="notification-bell">
            <svg class="w-6 h-6 text-gray-700 dark:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
            </svg>
            <% if (current_user&.unread_notifications_count || 0) > 0 %>
              <span class="notification-badge"><%= current_user.unread_notifications_count %></span>
            <% end %>
          </button>

          <!-- Notification Dropdown (keep existing implementation) -->
          <div data-notifications-target="dropdown" class="hidden absolute right-0 mt-2 w-80 bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-rose-100 dark:border-gray-700 z-50">
            <!-- ... existing notification dropdown content ... -->
          </div>
        </div>

        <!-- Dark Mode Toggle -->
        <div
          data-controller="theme"
          data-theme-current-value="<%= user_signed_in? ? current_user.theme_preference : (session[:theme_preference] || 'system') %>"
          data-theme-authenticated-value="<%= user_signed_in? %>"
        >
          <button
            data-action="click->theme#toggle"
            data-theme-target="toggle"
            class="dark-mode-toggle"
          >
            <svg class="dark-mode-icon-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
            </svg>
            <svg class="dark-mode-icon-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
          </button>
        </div>

        <!-- User Avatar + Dropdown -->
        <div class="relative" data-controller="dropdown">
          <button data-action="click->dropdown#toggle" class="flex items-center space-x-3 p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition">
            <% if current_user&.avatar_url.present? %>
              <img src="<%= current_user.avatar_url %>" alt="Avatar" class="user-avatar">
            <% else %>
              <div class="user-avatar bg-gradient-to-br from-rose-500 to-pink-500 flex items-center justify-center">
                <span class="text-sm font-semibold text-white">
                  <%= current_user&.name&.first&.upcase || current_user&.email&.first&.upcase %>
                </span>
              </div>
            <% end %>
            <div class="hidden xl:block text-left">
              <p class="text-sm font-bold text-gray-800 dark:text-gray-100"><%= current_user&.name || "User" %></p>
              <p class="text-xs text-gray-500 dark:text-gray-400"><%= current_user&.email %></p>
            </div>
            <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>

          <!-- User Dropdown (Simplified) -->
          <div data-dropdown-target="menu" class="user-dropdown">
            <div class="px-4 py-3 border-b border-gray-100 dark:border-gray-700">
              <p class="text-sm font-medium text-gray-800 dark:text-gray-200"><%= current_user&.name || "User" %></p>
              <p class="text-xs text-gray-500 dark:text-gray-400"><%= current_user&.email %></p>
            </div>

            <%= link_to edit_user_registration_path, class: "dropdown-item" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
              <%= t('profile.edit.title') %>
            <% end %>

            <%= link_to user_path(current_user), class: "dropdown-item" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <%= t('navigation.view_public_profile') %>
            <% end %>

            <div class="dropdown-divider"></div>

            <%= link_to destroy_user_session_path,
                  data: { "turbo-method": :delete },
                  class: "dropdown-item text-rose-600 dark:text-rose-400" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
              </svg>
              <%= t('navigation.sign_out') %>
            <% end %>
          </div>
        </div>
      </div>

    </div>
  </div>
</nav>

<!-- Mobile Bottom Navigation -->
<nav class="nav-mobile bottom-nav lg:hidden">
  <div class="bottom-nav-grid">
    <!-- Dashboard -->
    <%= link_to root_path, class: "bottom-nav-item #{request.path == root_path ? 'active' : ''}" do %>
      <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
      </svg>
      <span class="text-xs font-medium"><%= t('navigation.home') %></span>
    <% end %>

    <!-- Wishlists -->
    <%= link_to wishlists_path, class: "bottom-nav-item #{request.path.match?(/\/wishlists/) ? 'active' : ''}" do %>
      <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path>
      </svg>
      <span class="text-xs font-medium"><%= t('navigation.lists') %></span>
    <% end %>

    <!-- Add (FAB) -->
    <div class="bottom-nav-fab">
      <%= link_to new_wishlist_path, class: "fab-button" do %>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
      <% end %>
    </div>

    <!-- Connections -->
    <%= link_to connections_path, class: "bottom-nav-item #{request.path.match?(/\/connections/) ? 'active' : ''}" do %>
      <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
      </svg>
      <span class="text-xs font-medium"><%= t('navigation.friends') %></span>
    <% end %>

    <!-- Profile -->
    <%= link_to user_path(current_user), class: "bottom-nav-item #{request.path == user_path(current_user) ? 'active' : ''}" do %>
      <div class="w-6 h-6 mb-1">
        <% if current_user&.avatar_url.present? %>
          <img src="<%= current_user.avatar_url %>" alt="Profile" class="user-avatar-small">
        <% else %>
          <div class="user-avatar-small bg-gradient-to-br from-rose-500 to-pink-500 flex items-center justify-center">
            <span class="text-xs font-bold text-white">
              <%= current_user&.name&.first&.upcase || "U" %>
            </span>
          </div>
        <% end %>
      </div>
      <span class="text-xs font-medium"><%= t('navigation.profile') %></span>
    <% end %>
  </div>
</nav>
